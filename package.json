{
  "name": "openclaw-grok",
  "version": "0.1.0",
  "private": true,
  "description": "OpenClaw integration for the Grok CLI as a first-class coding agent via the Agent Client Protocol (ACP). Monorepo containing grok-harness (ACP hardening) and openclaw-plugin (OpenClaw provider bridge).",
  "license": "MIT",
  "author": "Jesse Smith & Grok Build",
  "contributors": [
    "Jesse Smith",
    "Grok Build <grok-build@x.ai>"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/the-jesse/openclaw-grok.git"
  },
  "bugs": {
    "url": "https://github.com/the-jesse/openclaw-grok/issues"
  },
  "homepage": "https://github.com/the-jesse/openclaw-grok#readme",
  "keywords": [
    "openclaw",
    "grok",
    "acp",
    "agent-client-protocol",
    "coding-agent",
    "xai"
  ],
  "packageManager": "pnpm@10.8.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "prepare": "husky",
    "build": "pnpm -r --filter='./packages/*' build",
    "clean": "pnpm -r --filter='./packages/*' clean",
    "lint": "pnpm -r --filter='./packages/*' lint",
    "lint:fix": "pnpm -r --filter='./packages/*' lint:fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r --filter='./packages/*' typecheck",
    "test": "echo \"No tests yet (Phase 0 scaffolding)\" && exit 0",
    "changeset": "echo \"Use conventional commits; changesets in future\""
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@eslint/js": "^9.26.0",
    "@types/node": "^22.15.0",
    "eslint": "^9.26.0",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.0"
  },
  "lint-staged": {
    "*.{ts,js,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{ts,js}": [
      "eslint --fix"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": []
  }
}
